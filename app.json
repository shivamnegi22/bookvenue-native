{
"expo": {
"name": "BookVenue",
"slug": "book-venue",
"version": "1.0.0",
"orientation": "portrait",
"icon": "./assets/images/icon.png",
"scheme": "myapp",
"userInterfaceStyle": "automatic",

// "ios": {
//   "supportsTablet": true,
//   "bundleIdentifier": "com.shivamnegi.bookvenue",
//   "googleServicesFile": "./GoogleService-Info.plist",
//   "infoPlist": {
//     "ITSAppUsesNonExemptEncryption": false
//   },
//   "entitlements": {
//     "aps-environment": "production"
//   }
// },
"ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.giksindia.bookvenue",
  "googleServicesFile": "./GoogleService-Info.plist",

  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false,

    "NSPhotoLibraryUsageDescription": "BookVenue uses your photo library so you can upload and update your profile picture and share venue-related images.",

    "NSPhotoLibraryAddUsageDescription": "BookVenue saves downloaded venue images and booking-related media to your photo library.",

    "NSCameraUsageDescription": "BookVenue uses your camera so you can capture and upload profile pictures and venue images."
  },

  "entitlements": {
    "aps-environment": "production"
  }
}
,
"android": {
  "googleServicesFile": "./google-services.json",
  "adaptiveIcon": {
    "foregroundImage": "./assets/images/adaptive_icon2-removebg.png",
    "backgroundColor": "#ffffff"
  },
  "package": "com.giksindia.bookvenue",
  "config": {
    "googleMaps": {
      "apiKey": "AIzaSyCvcX-wdx9MFmhsYrcNpvTz49KQkHFE73Y"
    }
  },
  "permissions": [
    "android.permission.INTERNET",
    "android.permission.ACCESS_NETWORK_STATE",
    "android.permission.ACCESS_FINE_LOCATION",
    "android.permission.ACCESS_COARSE_LOCATION",
    "android.permission.CAMERA",
    "android.permission.READ_EXTERNAL_STORAGE",
    "android.permission.WRITE_EXTERNAL_STORAGE",
    "android.permission.RECORD_AUDIO"
  ],
  "allowBackup": true
},

"web": {
  "bundler": "metro",
  "output": "single",
  "favicon": "./assets/images/BookVenue_Logo.png"
},

"plugins": [
  "expo-router",
  "expo-font",
  "expo-web-browser",
[ "expo-image-picker", { "photosPermission": "BookVenue uses your photos so you can upload and update your profile picture and share venue images.", "cameraPermission": "BookVenue uses your camera so you can capture and upload profile pictures and venue images." } ],

  [
    "@stripe/stripe-react-native",
    {
      "merchantIdentifier": "merchant.com.bookvenue",
      "enableGooglePay": true
    }
  ],

  [
    "expo-build-properties",
    {

      "android": {
        "usesCleartextTraffic": true,
        "enableProguardInReleaseBuilds": false,
        "enableShrinkResourcesInReleaseBuilds": false,
        "enableMinifyInReleaseBuilds": false
      }
    }
  ]
],

"experiments": {
  "typedRoutes": true
},

"splash": {
  "image": "./assets/images/Splash-screen.png",
  "resizeMode": "contain",
  "backgroundColor": "#ffffff"
},

"updates": {
  "fallbackToCacheTimeout": 0
},

"runtimeVersion": {
  "policy": "sdkVersion"
},

"extra": {
  "router": {},
  "eas": {
    "projectId": "c9d390b2-108a-4a38-a4e1-eeb066b0a9c5"
  }
}

}
}